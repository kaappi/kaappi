(import (scheme base) (scheme read) (scheme write) (scheme time))

(define *bench-runs* 5)

(define (bench-sort lst)
  (if (or (null? lst) (null? (cdr lst))) lst
      (let* ((pivot (car lst))
             (rest (cdr lst)))
        (let partition ((remaining rest) (lo '()) (hi '()))
          (cond ((null? remaining)
                 (append (bench-sort lo) (cons pivot (bench-sort hi))))
                ((< (car remaining) pivot)
                 (partition (cdr remaining) (cons (car remaining) lo) hi))
                (else
                 (partition (cdr remaining) lo (cons (car remaining) hi))))))))

(define (run-r7rs-benchmark name count thunk verify)
  (let ((jps (jiffies-per-second)))
    ;; Warmup: one untimed run
    (let warmup ((i count) (result #f))
      (if (= i 0) result
          (warmup (- i 1) (thunk))))
    ;; Measured runs
    (let outer ((run 0) (times '()) (last-result #f))
      (if (= run *bench-runs*)
          (let* ((sorted (bench-sort times))
                 (median (list-ref sorted (quotient *bench-runs* 2)))
                 (mn (car sorted))
                 (mx (list-ref sorted (- *bench-runs* 1))))
            (display "name: ")
            (display name)
            (display ", time: ")
            (display median)
            (display ", status: ")
            (if (verify last-result)
                (display "ok")
                (display "fail"))
            (display ", min: ")
            (display mn)
            (display ", max: ")
            (display mx)
            (display ", iterations: ")
            (display *bench-runs*)
            (newline))
          (let ((t0 (current-jiffy)))
            (let inner ((i count) (result #f))
              (if (= i 0)
                  (let* ((t1 (current-jiffy))
                         (elapsed (inexact (/ (- t1 t0) jps))))
                    (outer (+ run 1) (cons elapsed times) result))
                  (inner (- i 1) (thunk)))))))))

(define (hide r x) (if (= r 0) x (hide (- r 1) x)))
