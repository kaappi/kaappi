(import (scheme base) (scheme read) (scheme write) (scheme time))

(define (run-r7rs-benchmark name count thunk verify)
  (let ((start (current-jiffy)))
    (let loop ((i count) (result #f))
      (if (= i 0)
          (let* ((end (current-jiffy))
                 (jps (jiffies-per-second))
                 (elapsed (inexact (/ (- end start) jps))))
            (display name)
            (display ": ")
            (display elapsed)
            (display "s")
            (if (verify result)
                (display " [OK]")
                (display " [FAIL]"))
            (newline))
          (loop (- i 1) (thunk))))))

(define (vector-bench n)
  (let ((v (make-vector n 0)))
    (let fill ((i 0))
      (when (< i n)
        (vector-set! v i (* i i))
        (fill (+ i 1))))
    (let sum ((i 0) (total 0))
      (if (= i n) total
          (sum (+ i 1) (+ total (vector-ref v i)))))))

(let* ((count (read))
       (input (read))
       (expected (read)))
  (run-r7rs-benchmark
   (string-append "vector(" (number->string input) ")")
   count
   (lambda () (vector-bench input))
   (lambda (result) (= result expected))))
