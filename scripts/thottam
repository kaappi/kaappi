#!/bin/bash
# thottam — package manager for Kaappi Scheme
# Usage: thottam install <package>[@<tag|commit>]
#        thottam remove <package>
#        thottam list
#        thottam update [package]
#        thottam verify
#
# Flags:
#        --locked    Refuse to install packages not in the lockfile
#
# Security note: thottam clones from github.com/kaappi/<package>, runs
# the build: command from kaappi.pkg (arbitrary shell), and copies .sld
# and native libraries (.dylib/.so) to ~/.kaappi/lib/ which is auto-loaded
# by the Kaappi interpreter. Review kaappi.pkg before installing unfamiliar
# packages.
set -e

KAAPPI_HOME="${KAAPPI_HOME:-$HOME/.kaappi}"
KAAPPI_ORG="https://github.com/kaappi"
LIB_DIR="$KAAPPI_HOME/lib"
SRC_DIR="$KAAPPI_HOME/src"
INSTALLED="$KAAPPI_HOME/installed.txt"
LOCKFILE="$KAAPPI_HOME/thottam.lock"

UNAME=$(uname)
if [ "$UNAME" = "Darwin" ]; then
    DYLIB_EXT="dylib"
else
    DYLIB_EXT="so"
fi

LOCKED_MODE=false

ensure_dirs() {
    mkdir -p "$LIB_DIR" "$SRC_DIR"
    touch "$INSTALLED"
}

is_installed() {
    grep -qx "$1" "$INSTALLED" 2>/dev/null
}

# Parse package@version into PKG_NAME and PKG_VERSION
parse_pkg_spec() {
    local spec="$1"
    if [[ "$spec" == *@* ]]; then
        PKG_NAME="${spec%%@*}"
        PKG_VERSION="${spec#*@}"
    else
        PKG_NAME="$spec"
        PKG_VERSION=""
    fi
}

# Read kaappi.pkg and extract field value
pkg_field() {
    local pkg_dir="$1" field="$2"
    local file="$pkg_dir/kaappi.pkg"
    if [ -f "$file" ]; then
        grep "^${field}:" "$file" | sed "s/^${field}: *//"
    fi
}

# Get the current commit SHA for a package
get_pkg_sha() {
    local pkg="$1"
    if [ -d "$SRC_DIR/$pkg/.git" ]; then
        git -C "$SRC_DIR/$pkg" rev-parse HEAD
    fi
}

# Read the locked SHA for a package from the lockfile
get_locked_sha() {
    local pkg="$1"
    if [ -f "$LOCKFILE" ]; then
        grep "^${pkg} " "$LOCKFILE" | awk '{print $2}'
    fi
}

# Write or update a package entry in the lockfile
update_lockfile() {
    local pkg="$1" sha="$2"
    if [ -f "$LOCKFILE" ] && grep -q "^${pkg} " "$LOCKFILE"; then
        # Update existing entry
        if [ "$UNAME" = "Darwin" ]; then
            sed -i '' "s|^${pkg} .*|${pkg} ${sha}|" "$LOCKFILE"
        else
            sed -i "s|^${pkg} .*|${pkg} ${sha}|" "$LOCKFILE"
        fi
    else
        echo "${pkg} ${sha}" >> "$LOCKFILE"
    fi
}

# Remove a package entry from the lockfile
remove_from_lockfile() {
    local pkg="$1"
    if [ -f "$LOCKFILE" ]; then
        grep -v "^${pkg} " "$LOCKFILE" > "$LOCKFILE.tmp" || true
        mv "$LOCKFILE.tmp" "$LOCKFILE"
    fi
}

do_install() {
    local spec="$1"
    parse_pkg_spec "$spec"
    local pkg="$PKG_NAME"
    local version="$PKG_VERSION"

    if is_installed "$pkg"; then
        echo "  $pkg already installed"
        return
    fi

    # In --locked mode, refuse to install unless the package is in the lockfile
    if $LOCKED_MODE; then
        local locked_sha
        locked_sha=$(get_locked_sha "$pkg")
        if [ -z "$locked_sha" ]; then
            echo "error: $pkg is not in the lockfile (running in --locked mode)"
            exit 1
        fi
        version="$locked_sha"
    fi

    echo "Installing $pkg${version:+@$version}..."

    # Clone if not already present
    if [ ! -d "$SRC_DIR/$pkg" ]; then
        echo "  Cloning $KAAPPI_ORG/$pkg..."
        git clone --quiet "$KAAPPI_ORG/$pkg.git" "$SRC_DIR/$pkg"
    fi

    # Checkout specific version if requested
    if [ -n "$version" ]; then
        echo "  Checking out $version..."
        (cd "$SRC_DIR/$pkg" && git fetch --quiet --tags && git checkout --quiet "$version")
    fi

    # Verify integrity: record the resolved commit SHA
    local resolved_sha
    resolved_sha=$(get_pkg_sha "$pkg")
    echo "  Resolved: $resolved_sha"

    # In --locked mode, verify SHA matches lockfile
    if $LOCKED_MODE; then
        local locked_sha
        locked_sha=$(get_locked_sha "$pkg")
        if [ -n "$locked_sha" ] && [ "$resolved_sha" != "$locked_sha" ]; then
            echo "error: SHA mismatch for $pkg (locked: $locked_sha, got: $resolved_sha)"
            exit 1
        fi
    fi

    # Install dependencies first
    local deps
    deps=$(pkg_field "$SRC_DIR/$pkg" "depends")
    if [ -n "$deps" ]; then
        for dep in $deps; do
            do_install "$dep"
        done
    fi

    # Build if needed
    local build_cmd
    build_cmd=$(pkg_field "$SRC_DIR/$pkg" "build")
    if [ -n "$build_cmd" ]; then
        echo "  Building $pkg..."
        (cd "$SRC_DIR/$pkg" && $build_cmd)
    fi

    # Copy .sld files (preserving directory structure)
    if [ -d "$SRC_DIR/$pkg/lib" ]; then
        echo "  Installing libraries..."
        cp -R "$SRC_DIR/$pkg/lib/"* "$LIB_DIR/"
    fi

    # Copy dylibs
    local dylib_count=0
    for f in "$SRC_DIR/$pkg"/*."$DYLIB_EXT"; do
        if [ -f "$f" ]; then
            cp "$f" "$LIB_DIR/"
            dylib_count=$((dylib_count + 1))
        fi
    done
    if [ "$dylib_count" -gt 0 ]; then
        echo "  Installed $dylib_count native library(s)"
    fi

    echo "$pkg" >> "$INSTALLED"
    update_lockfile "$pkg" "$resolved_sha"
    echo "  $pkg installed (locked at $resolved_sha)"
}

do_remove() {
    local pkg="$1"

    if ! is_installed "$pkg"; then
        echo "$pkg is not installed"
        return 1
    fi

    echo "Removing $pkg..."

    # Remove .sld files that belong to this package
    if [ -d "$SRC_DIR/$pkg/lib" ]; then
        (cd "$SRC_DIR/$pkg/lib" && find . -name "*.sld" -print) | while read -r f; do
            rm -f "$LIB_DIR/$f"
        done
    fi

    # Remove dylibs
    for f in "$SRC_DIR/$pkg"/*."$DYLIB_EXT"; do
        if [ -f "$f" ]; then
            rm -f "$LIB_DIR/$(basename "$f")"
        fi
    done

    # Remove from installed list
    grep -vx "$pkg" "$INSTALLED" > "$INSTALLED.tmp" && mv "$INSTALLED.tmp" "$INSTALLED"

    # Remove from lockfile
    remove_from_lockfile "$pkg"

    # Remove source
    rm -rf "${SRC_DIR:?}/$pkg"

    echo "  $pkg removed"
}

do_list() {
    if [ ! -f "$INSTALLED" ] || [ ! -s "$INSTALLED" ]; then
        echo "No packages installed"
        return
    fi
    echo "Installed packages:"
    while IFS= read -r pkg; do
        local sha deps desc=""
        sha=$(get_locked_sha "$pkg")
        if [ -f "$SRC_DIR/$pkg/kaappi.pkg" ]; then
            deps=$(pkg_field "$SRC_DIR/$pkg" "depends")
            if [ -n "$deps" ]; then
                desc=" (depends: $deps)"
            fi
        fi
        echo "  $pkg  ${sha:0:12}$desc"
    done < "$INSTALLED"
}

do_update() {
    local pkg="$1"

    if [ -n "$pkg" ]; then
        # Update single package
        if ! is_installed "$pkg"; then
            echo "$pkg is not installed"
            return 1
        fi
        echo "Updating $pkg..."
        (cd "$SRC_DIR/$pkg" && git pull --quiet)
        local build_cmd
        build_cmd=$(pkg_field "$SRC_DIR/$pkg" "build")
        if [ -n "$build_cmd" ]; then
            (cd "$SRC_DIR/$pkg" && $build_cmd)
        fi
        if [ -d "$SRC_DIR/$pkg/lib" ]; then
            cp -R "$SRC_DIR/$pkg/lib/"* "$LIB_DIR/"
        fi
        for f in "$SRC_DIR/$pkg"/*."$DYLIB_EXT"; do
            [ -f "$f" ] && cp "$f" "$LIB_DIR/"
        done
        local new_sha
        new_sha=$(get_pkg_sha "$pkg")
        update_lockfile "$pkg" "$new_sha"
        echo "  $pkg updated (now at $new_sha)"
    else
        # Update all
        if [ ! -f "$INSTALLED" ] || [ ! -s "$INSTALLED" ]; then
            echo "No packages to update"
            return
        fi
        while IFS= read -r p; do
            do_update "$p"
        done < "$INSTALLED"
    fi
}

do_verify() {
    if [ ! -f "$LOCKFILE" ]; then
        echo "No lockfile found"
        return 1
    fi
    echo "Verifying installed packages against lockfile..."
    local ok=true
    while IFS=' ' read -r pkg locked_sha; do
        local current_sha
        current_sha=$(get_pkg_sha "$pkg")
        if [ -z "$current_sha" ]; then
            echo "  MISSING: $pkg (not cloned)"
            ok=false
        elif [ "$current_sha" != "$locked_sha" ]; then
            echo "  MISMATCH: $pkg (locked: ${locked_sha:0:12}, actual: ${current_sha:0:12})"
            ok=false
        else
            echo "  OK: $pkg (${locked_sha:0:12})"
        fi
    done < "$LOCKFILE"
    if $ok; then
        echo "All packages verified."
    else
        echo "Verification failed."
        return 1
    fi
}

# --- Main ---

# Parse global flags
while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --locked)
            LOCKED_MODE=true
            shift
            ;;
        *)
            echo "Unknown flag: $1"
            exit 1
            ;;
    esac
done

ensure_dirs

case "${1:-}" in
    install)
        [ -z "${2:-}" ] && { echo "Usage: thottam install <package>[@<version>]"; exit 1; }
        do_install "$2"
        ;;
    remove)
        [ -z "${2:-}" ] && { echo "Usage: thottam remove <package>"; exit 1; }
        do_remove "$2"
        ;;
    list)
        do_list
        ;;
    update)
        do_update "${2:-}"
        ;;
    verify)
        do_verify
        ;;
    *)
        echo "thottam — package manager for Kaappi Scheme"
        echo ""
        echo "Usage: thottam [--locked] <command> [args]"
        echo ""
        echo "Commands:"
        echo "  install <package>[@<tag|commit>]   Install a package (optionally pinned)"
        echo "  remove <package>                   Remove a package"
        echo "  list                               List installed packages with commit SHAs"
        echo "  update [package]                   Update one or all packages"
        echo "  verify                             Check installs match the lockfile"
        echo ""
        echo "Flags:"
        echo "  --locked   Refuse to install packages not in the lockfile"
        echo ""
        echo "Packages are installed to ~/.kaappi/lib/"
        echo "Lockfile: ~/.kaappi/thottam.lock"
        echo ""
        echo "Security: thottam runs the build: command from kaappi.pkg and copies"
        echo "native libraries to ~/.kaappi/lib/ (auto-loaded by ffi-open). Review"
        echo "package manifests before installing from untrusted sources."
        ;;
esac
