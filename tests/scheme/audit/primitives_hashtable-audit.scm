;; Audit tests for src/primitives_hashtable.zig — SRFI-69 hash tables.
;; Audit campaign Phase 2.11 (#1137).
;; Run directly and read the printed counts — run-all.sh only sees exit codes.

(import (scheme base) (scheme write) (srfi 69))
(import (chibi test))

(test-begin "primitives_hashtable audit")

;;; --- constructors and predicate ---
(test #t (hash-table? (make-hash-table)))
(test #f (hash-table? '((a . 1))))
(test #f (hash-table? #(1 2)))
(test 0 (hash-table-size (make-hash-table)))

;;; --- set! / ref / ref/default ---
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht 'k 'v)
           (hash-table-ref ht 'k)))
(test 'new (let ((ht (make-hash-table)))
             (hash-table-set! ht 'k 'old)
             (hash-table-set! ht 'k 'new)     ; overwrite, size stays 1
             (hash-table-ref ht 'k)))
(test 1 (let ((ht (make-hash-table)))
          (hash-table-set! ht 'k 'old)
          (hash-table-set! ht 'k 'new)
          (hash-table-size ht)))
(test 'from-thunk (hash-table-ref (make-hash-table) 'missing (lambda () 'from-thunk)))
(test 'dflt (hash-table-ref/default (make-hash-table) 'missing 'dflt))
(test 'caught (guard (e (#t 'caught)) (hash-table-ref (make-hash-table) 'missing)))
(test 'caught (guard (e (#t 'caught))
                (hash-table-ref (make-hash-table) 'missing (lambda () (error "boom")))))
(test 'caught (guard (e (#t 'caught)) (hash-table-ref '((a . 1)) 'a)))
(test 'caught (guard (e (#t 'caught)) (hash-table-set! "not-ht" 'k 'v)))

;;; --- key type coverage: hash/equality must agree for immediates,
;;;     strings, symbols, chars, and shallow structures ---
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht "key" 'v)
           (hash-table-ref/default ht (string-copy "key") 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht #\x 'v)
           (hash-table-ref/default ht #\x 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht 42 'v)
           (hash-table-ref/default ht 42 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht 1.5 'v)
           (hash-table-ref/default ht 1.5 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht #t 'v)
           (hash-table-ref/default ht #t 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht '() 'v)
           (hash-table-ref/default ht '() 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht (list 1 2) 'v)
           (hash-table-ref/default ht (list 1 2) 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht (vector 1 "a") 'v)
           (hash-table-ref/default ht (vector 1 "a") 'missing)))
(test 'v (let ((ht (make-hash-table)))
           (hash-table-set! ht (bytevector 1 2) 'v)
           (hash-table-ref/default ht (bytevector 1 2) 'missing)))
;; Heap-boxed numeric keys hash by pointer while lookup compares by equal? —
;; entries become unfindable once the table grows past one bucket-group
;; (verified: 27/30 bignum and 28/30 rational lookups miss at 30 entries).
;; Same class: pairs/vectors nested deeper than the depth-8 hash cutoff.
