;;             misses)))

;;; --- growth: many entries stay findable (fixnum/string/symbol keys) ---
(test 0 (let ((ht (make-hash-table)))
          (do ((i 0 (+ i 1))) ((= i 100))
            (hash-table-set! ht i (* i i)))
          (let ((misses 0))
            (do ((i 0 (+ i 1))) ((= i 100))
              (if (not (equal? (* i i) (hash-table-ref/default ht i 'missing)))
                  (set! misses (+ misses 1))))
            misses)))
(test 100 (let ((ht (make-hash-table)))
            (do ((i 0 (+ i 1))) ((= i 100))
              (hash-table-set! ht i i))
            (hash-table-size ht)))

;;; --- exists? / delete! ---
(test #t (let ((ht (make-hash-table)))
           (hash-table-set! ht 'k 'v)
           (hash-table-exists? ht 'k)))
(test #f (hash-table-exists? (make-hash-table) 'k))
(test '(#f 0) (let ((ht (make-hash-table)))
                (hash-table-set! ht 'k 'v)
                (hash-table-delete! ht 'k)
                (list (hash-table-exists? ht 'k) (hash-table-size ht))))
;; deleting a missing key is a no-op
(test 1 (let ((ht (make-hash-table)))
          (hash-table-set! ht 'k 'v)
          (hash-table-delete! ht 'other)
          (hash-table-size ht)))
;; delete then re-insert (tombstone reuse)
(test 'v2 (let ((ht (make-hash-table)))
            (hash-table-set! ht 'k 'v1)
            (hash-table-delete! ht 'k)
            (hash-table-set! ht 'k 'v2)
            (hash-table-ref ht 'k)))

;;; --- keys / values / ->alist ---
(test '(a b) (let ((ht (make-hash-table)))
               (hash-table-set! ht 'a 1)
               (hash-table-set! ht 'b 2)
               (let ((ks (hash-table-keys ht)))
                 (if (memq 'a ks) (if (memq 'b ks) (list 'a 'b) 'missing-b) 'missing-a))))
(test 3 (let ((ht (make-hash-table)))
          (hash-table-set! ht 'a 1)
          (hash-table-set! ht 'b 2)
          (let loop ((vs (hash-table-values ht)) (sum 0))
            (if (null? vs) sum (loop (cdr vs) (+ sum (car vs)))))))
(test '((k . v)) (let ((ht (make-hash-table)))
                   (hash-table-set! ht 'k 'v)
                   (hash-table->alist ht)))
(test '() (hash-table->alist (make-hash-table)))

;;; --- alist->hash-table ---
(test 2 (hash-table-size (alist->hash-table '((a . 1) (b . 2)))))
;; SRFI-69: earlier associations take precedence
(test 1 (hash-table-ref (alist->hash-table '((k . 1) (k . 2))) 'k))
(test 0 (hash-table-size (alist->hash-table '())))
;; 12 entries (non-power-of-two count) all retrievable
(test '(12 12 1)
    (let ((ht (alist->hash-table '((a . 1) (b . 2) (c . 3) (d . 4) (e . 5) (f . 6)
                                  (g . 7) (h . 8) (i . 9) (j . 10) (k . 11) (l . 12)))))
      (list (hash-table-size ht)
            (hash-table-ref/default ht 'l 'missing)
            (hash-table-ref/default ht 'a 'missing))))
(test 'caught (guard (e (#t 'caught)) (alist->hash-table '(not-a-pair))))
(test 'caught (guard (e (#t 'caught)) (alist->hash-table 42)))

;;; --- walk / fold ---
(test 6 (let ((ht (make-hash-table)) (sum 0))
          (hash-table-set! ht 'a 1)
          (hash-table-set! ht 'b 2)
          (hash-table-set! ht 'c 3)
          (hash-table-walk ht (lambda (k v) (set! sum (+ sum v))))
          sum))
(test 6 (let ((ht (make-hash-table)))
          (hash-table-set! ht 'a 1)
          (hash-table-set! ht 'b 2)
          (hash-table-set! ht 'c 3)
          (hash-table-fold ht (lambda (k v acc) (+ acc v)) 0)))
(test 0 (hash-table-fold (make-hash-table) (lambda (k v acc) (+ acc 1)) 0))
(test 'caught (guard (e (#t 'caught))
                (let ((ht (make-hash-table)))
                  (hash-table-set! ht 'k 'v)
                  (hash-table-walk ht (lambda (k v) (error "boom"))))))
(test 'caught (guard (e (#t 'caught))
                (let ((ht (make-hash-table)))
                  (hash-table-set! ht 'k 'v)
                  (hash-table-fold ht (lambda (k v acc) (error "boom")) 0))))
;; mutation during walk: inserting during iteration must not crash;
;; all original entries are still visited (snapshot semantics)
(test 3 (let ((ht (make-hash-table)) (seen 0))
          (hash-table-set! ht 'a 1)
          (hash-table-set! ht 'b 2)
          (hash-table-set! ht 'c 3)
          (hash-table-walk ht (lambda (k v)
                                (hash-table-set! ht (list k) v)
                                (set! seen (+ seen 1))))
          seen))
;; The walk/fold snapshot is invisible to the GC: if the callback deletes
;; entries and allocates, the snapshot's keys/values are freed and reused,
;; and the callback receives corrupted pairs. Passes on a default build;
;; fails under -Dgc-stress=true (verified: 29/30 entries corrupted).
;; FAIL: #1181 (walk/fold snapshot unrooted — use-after-free under GC pressure)
